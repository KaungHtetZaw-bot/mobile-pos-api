generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id        Int      @id @default(autoincrement())
  roleId    Int
  name      String
  username  String   @unique
  email     String   @unique
  phone     String?
  avatar    String?
  password  String
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  role      Role     @relation(fields: [roleId], references: [id])
}

model Setting {
  id          Int      @id @default(autoincrement())
  shopName    String
  shopPhone   String
  shopAddress String
  currency    String
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MobileBrand {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?
  logo        String?
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  models      MobileModel[]
}

model MobileModel {
  id            Int         @id @default(autoincrement())
  brandId       Int
  modelName     String
  photo         String?
  storage       String
  ram           String
  color         String
  purchasePrice Float
  sellingPrice  Float
  stockQty      Int
  status        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  brand         MobileBrand @relation(fields: [brandId], references: [id])
  orderItems    OrderItem[]
}

model AccessoryCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OtherProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  invoiceNo     String      @unique
  customerName  String
  paymentMethod String
  remarks       String?
  userId        Int
  total         Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id            Int          @id @default(autoincrement())
  orderId       Int
  mobileModelId Int?
  quantity      Int
  sellingPrice  Float
  total         Float
  mobileModel   MobileModel? @relation(fields: [mobileModelId], references: [id])
  order         Order        @relation(fields: [orderId], references: [id])
}
